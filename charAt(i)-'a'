class Solution {
    public int firstUniqChar(String s) {
        int[] freq = new int[26];
        for(int i=0;i<s.length();i++)
        {
            freq[s.charAt(i)-'a']++;
        }
        for(int i=0;i<s.length();i++)
        {
            if(freq[s.charAt(i)-'a']==1)
            {
                return i;
            }
        }
        
    return -1;}
} ---- if it is a character like a --- it will return alphabet number (s.charAt(i)-'a'])

